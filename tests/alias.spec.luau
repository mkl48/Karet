-- leading-word alias expansion
local fw = require("./fwloader")
local Assert = require("./assert")
local Alias = fw.get("Alias")

return function(t)
	t.test("expands a leading alias", function()
		Assert.eq(Alias.expand("ll", { ll = "commands" }), "commands", "ll -> commands")
	end)
	t.test("keeps the rest of the line", function()
		Assert.eq(Alias.expand("ll -a", { ll = "commands" }), "commands -a", "args preserved")
	end)
	t.test("non-alias is unchanged", function()
		Assert.eq(Alias.expand("jump 5", { ll = "commands" }), "jump 5", "unchanged")
	end)
	t.test("recursive alias resolves", function()
		Assert.eq(Alias.expand("a", { a = "b", b = "echo hi" }), "echo hi", "a->b->echo hi")
	end)
	t.test("cycle doesn't hang", function()
		local r = Alias.expand("a", { a = "b", b = "a" })
		Assert.truthy(type(r) == "string", "returned without hanging")
	end)
	t.test("nil aliases is a no-op", function()
		Assert.eq(Alias.expand("ll", nil), "ll", "no-op")
	end)
end
