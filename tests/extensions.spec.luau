-- the extension/panel registry
local fw = require("./fwloader")
local Assert = require("./assert")
local Extensions = fw.get("Extensions")

return function(t)
	t.test("register + get + list panels", function()
		local x = Extensions.new()
		x:registerPanel({ Name = "Theme", Description = "switch", Open = function() end })
		x:registerPanel({ Name = "Inspector", Open = function() end })
		Assert.truthy(x:getPanel("theme"), "case-insensitive get")
		Assert.eq(#x:listPanels(), 2, "two panels")
		Assert.eq(x:listPanels()[1].Name, "Inspector", "sorted")
	end)
	t.test("panel requires Name + Open", function()
		local x = Extensions.new()
		Assert.falsy(pcall(function() x:registerPanel({ Open = function() end }) end), "needs a Name")
		Assert.falsy(pcall(function() x:registerPanel({ Name = "x" }) end), "needs an Open")
	end)
	t.test("extension metadata lists", function()
		local x = Extensions.new()
		x:addExtension({ Name = "Devtools", Description = "stuff" })
		Assert.eq(#x:listExtensions(), 1, "one extension")
		Assert.eq(x:listExtensions()[1].Name, "Devtools", "name")
	end)
end
