	Newline = "Newline",
	Semicolon = "Semicolon", -- ; (statement separator, same role as a newline)

	-- literals / words
	Number = "Number", -- 5, 3.14
	String = "String", -- "..."
	Boolean = "Boolean", -- true, false
	Ident = "Ident", -- names: commands, args, vars, labels, types

	-- references / sigils
	Slash = "Slash", -- /
	SlashSlash = "SlashSlash", -- //
	Dot = "Dot", -- .
	Hash = "Hash", -- #
	At = "At", -- @

	-- assignment / logic primitives
	Assign = "Assign", -- =
	Bang = "Bang", -- !
	Tilde = "Tilde", -- ~

	-- chain / boolean
	AmpAmp = "AmpAmp", -- &&
	PipePipe = "PipePipe", -- ||
	Amp = "Amp", -- &
	Pipe = "Pipe", -- | (pipeline: feed one command's output into the next)

	-- comparison
	EqEq = "EqEq", -- ==
	BangEq = "BangEq", -- !=
	Gte = "Gte", -- >=
	Lte = "Lte", -- <=
	Gt = "Gt", -- >
	Lt = "Lt", -- <

	-- arithmetic / dashes
	Plus = "Plus", -- +
	Minus = "Minus", -- -
	MinusMinus = "MinusMinus", -- --
	Star = "Star", -- *
	Percent = "Percent", -- %

	-- brackets
	LParen = "LParen", -- (
	RParen = "RParen", -- )
	LBrace = "LBrace", -- {
	RBrace = "RBrace", -- }
	LBracket = "LBracket", -- [
	RBracket = "RBracket", -- ]

	EOF = "EOF",
}

