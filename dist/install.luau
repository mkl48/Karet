	-- repeat a command ---------------------------------------------------------
	if services.run then
		add({
			Name = "repc",
			Aliases = { "loop", "rep-cmd" },
			Description = "run a command N times: repc jump 200  (pace it with --delay=0.5)",
			Network = "Client",
			Args = {
				{ Name = "command", Types = { "String" }, Required = true },
				{ Name = "times", Types = { "Integer" }, Required = true },
			},
			Modifiers = {
				{ Name = "delay", Types = { "Number" }, Default = 0, Description = "seconds between runs" },
			},
			On = { Client = function(ctx)
				local line = ctx.Args.command
				local maxTimes = (services.defaults and services.defaults.Repeat.MaxTimes) or 10000
				local times = math.clamp(ctx.Args.times, 1, maxTimes)
				local delay = ctx.Modifiers.delay or 0
				local ind = ctx.Indicator({ type = "progress", label = `{line} x{times}`, total = times })
				local fails = 0
				for i = 1, times do
					local r = services.run(line)
					if type(r) == "table" and r.ok == false then
						fails += 1
					end
					ind:Set(i)
					if delay > 0 then
						task.wait(delay)
					end
				end
				if fails > 0 then
					ind:Fail(`{line}: ran {times}x, {fails} failed`)
				else
					ind:Succeed(`{line}: ran {times}x`)
				end
				ctx.Return(times - fails)
			end },
		})
	end

	-- background jobs ----------------------------------------------------------
	if services.run and services.jobs then
		local jobs = services.jobs
		add({
			Name = "every",
			Aliases = { "interval" },
			Description = "run a command on a loop: every 5s jump  (stop it with: stop <id>)",
			Network = "Client",
			Args = {
				{ Name = "interval", Types = { "Duration" }, Required = true },
				{ Name = "command", Types = { "String" }, Required = true },
			},
			On = { Client = function(ctx)
				local interval = math.max(0.1, ctx.Args.interval)
				local line = ctx.Args.command
				local running = true
				local id = jobs.add(`every {interval}s: {line}`, function()
					running = false
				end)
				task.spawn(function()
					while running do
						services.run(line)
						local t = 0
						while running and t < interval do
							t += task.wait()
						end
					end
					jobs.remove(id)
				end)
				ctx.Success(`job {id} started: every {interval}s {line}`)
				ctx.Return(id)
			end },
		})
		add({
			Name = "watch",
			Aliases = { "onchange" },
			Description = 'run a command when an expressions value changes: watch health "notify ouch"',
			Network = "Client",
			Args = {
				{ Name = "expr", Types = { "String" }, Required = true },
				{ Name = "command", Types = { "String" }, Required = true },
			},
			Modifiers = {
				{ Name = "interval", Types = { "Number" }, Default = 0.5, Description = "seconds between polls" },
			},
			Flags = {
				{ Name = "immediate", Short = "i", Description = "also run once right away" },
			},
			On = { Client = function(ctx)
				local interval = math.max(0.1, ctx.Modifiers.interval or 0.5)
				local expr = ctx.Args.expr
				local line = ctx.Args.command
				-- read the watched expression and pull its first return value
				local function read(): any
					local r = services.run(expr)
					if type(r) == "table" and r.returns then
						return r.returns[1]
					end
					return nil
				end
				local running = true
				local id = jobs.add(`watch {expr}: {line}`, function()
					running = false
				end)
				task.spawn(function()
