	for index, atom in atoms do
		atomNames[index] = nameOf(atom)
	end
	channel.AtomNames = atomNames
	channel.Shape = mergeShape(atoms)

	Dispatch.Compose(name, channel.Shape, eventType)

	return { Name = name }
end

