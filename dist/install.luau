	if not recording then
		return
	end

	table.insert(history, {
		Name = name,
		Direction = direction,
		Payload = payload,
		Time = os.clock(),
	})
end

function Fossil.Replay(handler: (any) -> ())
	for _, entry in history do
		handler(entry)
	end
end

