	[K.Plus] = true,
	[K.Star] = true,
	[K.Percent] = true,
	[K.EqEq] = true,
	[K.BangEq] = true,
	[K.Gt] = true,
	[K.Lt] = true,
	[K.Gte] = true,
	[K.Lte] = true,
	[K.AmpAmp] = true,
	[K.PipePipe] = true,
