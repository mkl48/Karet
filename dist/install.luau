	return Connection.new(function(fire)
		local listeners = self._signals[state]
		local entry     = { fire = fire }
		table.insert(listeners, entry)

		return function()
			local i = table.find(listeners, entry)
			if i then table.remove(listeners, i) end
		end
	end)
end

