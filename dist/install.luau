	if type(definition) ~= "string" then
		return nil
	end

	if gluons[definition] then
		return gluons[definition]
	end

	if quarks[definition] then
		return quarks[definition]
	end

	local legacy = LEGACY_PRIMITIVES[definition]
	if legacy then
		return legacy()
	end

	return nil
end

