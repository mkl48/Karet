	local buf = self.buffers[self.active]
	if buf then
		buf.context = context
	end
	self:refreshMode()
end

function Kaveat:getSource(): string
	local buf = self.buffers[self.active]
	return buf and buf.source or ""
end

function Kaveat:setSource(source: string)
	local buf = self.buffers[self.active]
	if buf then
		buf.source = source
		self:showActive()
	end
end

function Kaveat:setRunner(runner: any)
	self.runner = runner
end

