	for _, s in locals do
		add(s, "local")
	end
	for _, s in funcs do
		add(s, "function")
	end
	for cls in classes do
		add(cls, "class")
	end
	for _, k in KEYWORDS do
		add(k, "keyword")
	end
	return out
end

return Complete
